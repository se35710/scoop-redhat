{
    "homepage": "https://github.com/openshift/source-to-image",
    "description": "A tool for building artifacts from source and injecting into container images.",
    "license": "Apache-2.0",
    "version": "1.6.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/openshift/source-to-image/releases/download/v1.6.0/source-to-image-v1.6.0-85b76928-windows-amd64.zip",
            "hash": "6990b34f614bfa76cbfb9b7f59eef8ff21beb8ea0ed8d73acc4e6ffa627c8baf"
        }
    },
    "bin": "s2i.exe",
    "checkver": {
        "script": [
            "$release = Invoke-RestMethod -Uri 'https://api.github.com/repos/openshift/source-to-image/releases/latest'",
            "$asset = $release.assets | Where-Object { $_.name -match 'windows-amd64\\.zip$' } | Select-Object -First 1",
            "if ($asset.name -match 'v([\\d.]+)-([\\da-f]{8})') {",
            "    Write-Output \"$($Matches[1]) $($Matches[2])\"",
            "}"
        ],
        "regex": "(?<version>[\\d.]+)\\s+(?<commit>[\\da-f]{8})"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openshift/source-to-image/releases/download/v$matchVersion/source-to-image-v$matchVersion-$matchCommit-windows-amd64.zip"
            }
        }
    }
}
